      <Value Profile="(Default)">https://farmers.com</Value>
    </Setting>
    <Setting Name="AutoSaveEnabled" Type="System.Boolean" Scope="User">
      <Value Profile="(Default)">True</Value>
    </Setting>
    <Setting Name="LogLevel" Type="System.Int32" Scope="User">
      <Value Profile="(Default)">0</Value>
    </Setting>
    <Setting Name="MaxLogEntries" Type="System.Int32" Scope="User">
      <Value Profile="(Default)">5000</Value>
